{
  "compilerOptions": {
    "target": "ES5",
    "module": "commonjs",
    "outDir": "build",

    /* ①  ——  librerie di tipizzazione più moderne  —— */
    "lib": ["ES5", "ES2015.Promise", "ES2015.Collection", "ES2021.String"],

    "strict": true,
    "esModuleInterop": true,
    "removeComments": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "spec/**/*.ts"
  ]
}
